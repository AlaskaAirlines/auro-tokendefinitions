{
  "name": "@aurodesignsystem/token-primitives",
  "version": "0.0.0",
  "description": "Alaska Air Auro Design System token primitive repository",
  "homepage": "https://github.com/AlaskaAirlines/DesignTokenPrimitives",
  "author": "Alaska Airlines Product design and engineering",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlaskaAirlines/AuroDesignTokenPrimitives"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": "^20.x || ^22.x"
  },
  "devDependencies": {
    "@aurodesignsystem/auro-config": "^1.3.0",
    "husky": "^9.1.7"
  },
  "scripts": {
    "prepare": "husky"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "alaska airlines",
    "css",
    "properties",
    "tokens"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./readme.md": "./README.md",
    "./alaska/*.json": "./tokens/alaska/*.json",
    "./alaska-classic/*.json": "./tokens/alaska-classic/*.json",
    "./auro-1/*.json": "./tokens/auro-1/*.json",
    "./auro-2/*.json": "./tokens/auro-2/*.json",
    "./base/*.json": "./tokens/base/*.json",
    "./base/type/*.json": "./tokens/base/type/*.json",
    "./hawaiian/*.json": "./tokens/hawaiian/*.json"
  },

  "files": [
    "tokens/**/*",
    "CHANGELOG.md",
    "README.md",
    "LICENSE",
    "NOTICE"
  ]
}
